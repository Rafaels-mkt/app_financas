# ============================================================
# Variáveis de Ambiente — Rotina Financeira do Rafa
# ============================================================
# 1. Copie este arquivo: cp .env.local.example .env.local
# 2. Preencha com seus valores do Supabase
# 3. NUNCA faça commit do arquivo .env.local
#
# Obtenha as chaves em:
#   https://supabase.com/dashboard/project/_/settings/api
# ============================================================

# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave pública (anon/publishable) — segura para o frontend.
# A segurança dos dados é garantida pelas políticas RLS no Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⚠️  NUNCA adicione aqui a Service Role Key.
#     Ela tem acesso total ao banco e jamais deve ir para o frontend.
